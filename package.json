{
  "name": "autowhats",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "tests": "npm run test:i18n:parity && npm run test:i18n:routes && npm run test:i18n:hardcoded && npm run test:unit:i18n && npm run test:backend:i18n && npm run test:e2e:i18n",
    "test:i18n:parity": "node --test --import tsx i18n-tests/parity.test.ts",
    "test:i18n:routes": "node --test --import tsx i18n-tests/routes.test.ts",
    "test:i18n:hardcoded": "node --test --import tsx i18n-tests/hardcoded.test.ts",
    "test:unit:i18n": "node --test --import tsx i18n-tests/unit.test.ts",
    "test:backend:i18n": "npm --prefix backend-b run test:i18n",
    "test:e2e:i18n": "playwright test tests/i18n.spec.ts",
    "generate:marketing-slides": "node video/scripts/openai/generate-marketing-slides.mjs",
    "generate:instagram": "node scripts/generate-instagram-posts.mjs",
    "generate:tutorial-assets": "node scripts/generate-tutorial-assets.mjs",
    "training:backfill-firestore": "tsx scripts/backfillTrainingCommercialDescription.ts",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --ignore-path .gitignore"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.7.0",
    "firebase-admin": "^13.6.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.441.0",
    "next": "^16.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.40",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.20.6",
    "typescript": "^5.5.4"
  }
}
