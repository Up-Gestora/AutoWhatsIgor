  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "seed:vsl": "tsx scripts/seed-vsl.ts",
    "post-feedback:backfill": "tsx scripts/backfillPostInteractionFeedback.ts",
    "training:backfill-postgres": "tsx scripts/backfillTrainingCommercialDescription.ts",
    "recovery:disconnected-session": "tsx scripts/recoverDisconnectedSessionBacklog.ts scan",
    "billing:reconcile": "tsx scripts/reconcileStripeBilling.ts",
    "billing:webhook:check": "tsx scripts/checkStripeWebhookStatus.ts",
    "test:i18n": "node --test --import tsx test/i18nPromptLanguage.test.ts",
    "test": "node --test --import tsx test/index.test.ts",
    "epic11:load": "tsx scripts/epic11Harness.ts load",
    "epic11:soak": "tsx scripts/epic11Harness.ts soak",
    "epic11:chaos": "tsx scripts/epic11Harness.ts chaos"
  },
  "dependencies": {
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.6",
    "@google/generative-ai": "^0.24.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.2.0",
    "fastify": "^4.28.1",
    "fastify-raw-body": "^4.2.1",
    "firebase-admin": "^13.6.0",
    "ioredis": "^5.4.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.11.5",
    "pino": "^10.3.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "stripe": "^18.0.0",
    "typescript": "^5.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.2"
  }
}
